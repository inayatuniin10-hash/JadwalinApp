<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FDE9D6"
    tools:context=".ui.auth.SplashActivity"> <ImageView
    android:id="@+id/logoImage"
    android:layout_width="250dp"
    android:layout_height="200dp"
    android:layout_marginBottom="16dp"
    android:contentDescription="Logo Jadwalin"
    android:src="@drawable/logo_jadwalin" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Jadwalin"
        android:textColor="#6D3600"
        android:textSize="40sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-light"
        android:text="Pengatur jadwalmu setiap hari"
        android:textColor="#904622"
        android:textSize="18sp"
        android:textStyle="italic" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:indeterminateTint="#A44930" /> </LinearLayout>